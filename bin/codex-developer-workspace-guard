#!/usr/bin/env python3
"""Enforce and install the Developer-only Codex project workspace guard."""

from __future__ import annotations

import argparse
import json
from pathlib import Path
import sys


sys.path.insert(0, str(Path(__file__).resolve().parent))

from codex_developer_workspace_guard import classify_event, decision_payload, install_guard


MAX_HOOK_INPUT_BYTES = 1024 * 1024


def _run_hook() -> int:
    raw = sys.stdin.buffer.read(MAX_HOOK_INPUT_BYTES + 1)
    if len(raw) > MAX_HOOK_INPUT_BYTES:
        print("codex-developer-workspace-guard: hook input exceeds 1 MiB", file=sys.stderr)
        return 2
    try:
        event = json.loads(raw.decode("utf-8"))
    except (UnicodeError, json.JSONDecodeError):
        print("codex-developer-workspace-guard: invalid hook input", file=sys.stderr)
        return 2
    if not isinstance(event, dict):
        print("codex-developer-workspace-guard: hook input must be an object", file=sys.stderr)
        return 2
    print(json.dumps(decision_payload(classify_event(event)), separators=(",", ":")))
    return 0


def _install(arguments: argparse.Namespace) -> int:
    try:
        result = install_guard(
            Path(arguments.codex_home),
            clean_records=arguments.clean_project_records,
        )
    except (OSError, UnicodeError, ValueError) as error:
        print(f"codex-developer-workspace-guard: installation refused: {error}", file=sys.stderr)
        return 2
    status = "installed" if result.hook_changed else "unchanged"
    print(f"Developer workspace guard: {status}; project-records-removed={result.project_records_removed}")
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    subparsers = parser.add_subparsers(dest="command")
    install = subparsers.add_parser("install")
    install.add_argument("--codex-home", required=True)
    install.add_argument("--clean-project-records", action="store_true")
    arguments = parser.parse_args()
    if arguments.command == "install":
        return _install(arguments)
    if arguments.command is not None:
        parser.error(f"unknown command: {arguments.command}")
    return _run_hook()


if __name__ == "__main__":
    raise SystemExit(main())
