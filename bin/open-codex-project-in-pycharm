#!/usr/bin/env zsh
set -eu
setopt extendedglob

require_github=false
project_dir="$PWD"
pycharm_app_path="${PYCHARM_APP_PATH:-/Applications/PyCharm.app}"
pycharm_open_command="${PYCHARM_OPEN_COMMAND:-/usr/bin/open}"
ready_interval="${PYCHARM_SERENA_READY_INTERVAL:-1}"
ready_timeout="${PYCHARM_SERENA_READY_TIMEOUT:-120}"
opener_state_dir="${PYCHARM_OPENER_STATE_DIR:-$HOME/.codex/state/pycharm-projects}"
opener_lock_dir="$opener_state_dir/opener.lock"
opener_lock_timeout="${PYCHARM_OPENER_LOCK_TIMEOUT:-30}"
reaper_command="${PYCHARM_PROJECT_REAPER_COMMAND:-$HOME/.codex/bin/pycharm-project-reaper}"
project_trust_command="${PYCHARM_PROJECT_TRUST_COMMAND:-$HOME/.codex/bin/pycharm-project-trust}"

usage() {
  print -u2 "Usage: open-codex-project-in-pycharm [--require-github] [PROJECT_DIR]"
}

has_github_remote() {
  local dir="$1"

  git -C "$dir" rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 1
  git -C "$dir" remote -v 2>/dev/null | grep -Eq 'github\.com[:/]'
}

is_open_in_pycharm() {
  local dir="$1"

  "$HOME/.codex/bin/serena-codex" jetbrains-service-status "$dir" >/dev/null 2>&1
}

ensure_project_trusted() {
  local dir="$1"

  [[ -x "$project_trust_command" ]] || return 1
  "$project_trust_command" allow "$dir"
}

release_opener_lock() {
  if [[ -d "$opener_lock_dir" && -f "$opener_lock_dir/owner" ]] \
      && grep -qx "pid=$$" "$opener_lock_dir/owner"; then
    rm -f "$opener_lock_dir/owner"
    rmdir "$opener_lock_dir" 2>/dev/null || true
  fi
}

lock_owner_is_live() {
  local owner_pid owner_started current_started current_command

  owner_pid="$(sed -n 's/^pid=//p' "$opener_lock_dir/owner" 2>/dev/null || true)"
  owner_started="$(sed -n 's/^process_started=//p' "$opener_lock_dir/owner" 2>/dev/null || true)"
  [[ "$owner_pid" == <-> && -n "$owner_started" ]] || return 0
  kill -0 "$owner_pid" 2>/dev/null || return 1
  current_started="$(ps -p "$owner_pid" -o lstart= 2>/dev/null | sed 's/^ *//;s/ *$//' || true)"
  current_command="$(ps -p "$owner_pid" -o command= 2>/dev/null || true)"
  [[ "$current_started" == "$owner_started" \
    && "$current_command" == *"open-codex-project-in-pycharm"* ]]
}

acquire_opener_lock() {
  local deadline process_started

  zmodload zsh/datetime
  mkdir -p -m 700 "$opener_state_dir"
  deadline=$(( EPOCHREALTIME + opener_lock_timeout ))
  while (( EPOCHREALTIME < deadline )); do
    if mkdir -m 700 "$opener_lock_dir" 2>/dev/null; then
      process_started="$(ps -p $$ -o lstart= | sed 's/^ *//;s/ *$//')"
      {
        print -r -- "pid=$$"
        print -r -- "process_started=$process_started"
        print -r -- "project_root=$project_dir"
      } > "$opener_lock_dir/owner"
      return 0
    fi
    if [[ -f "$opener_lock_dir/owner" ]] && ! lock_owner_is_live; then
      rm -f "$opener_lock_dir/owner"
      rmdir "$opener_lock_dir" 2>/dev/null || true
      continue
    fi
    sleep 0.1
  done

  print -u2 "open-codex-project-in-pycharm: timed out waiting for opener lock: $opener_lock_dir"
  return 1
}

wait_for_serena_service() {
  local dir="$1"
  local deadline

  zmodload zsh/datetime
  deadline=$(( EPOCHREALTIME + ready_timeout ))
  while (( EPOCHREALTIME < deadline )); do
    if is_open_in_pycharm "$dir"; then
      print "open-codex-project-in-pycharm: Serena service ready: $dir"
      return 0
    fi
    sleep "$ready_interval"
  done

  print -u2 "open-codex-project-in-pycharm: timed out waiting for Serena service after ${ready_timeout}s: $dir"
  return 1
}

update_reaper_registry() {
  local action="$1" dir="$2" confirmation
  [[ -x "$reaper_command" ]] || return 0
  if "$reaper_command" is-open "$dir"; then
    confirmation=0
  else
    confirmation=$?
  fi
  if [[ "$confirmation" -ne 0 ]]; then
    if [[ "$action" == touch && "$confirmation" -eq 1 ]]; then
      # An already-ready root can be unmanaged; do not create ownership for it.
      return 0
    fi
    if [[ "$confirmation" -eq 1 ]]; then
      print -u2 "open-codex-project-in-pycharm: reaper reports root not present in PyCharm inventory: $dir"
    else
      print -u2 "open-codex-project-in-pycharm: reaper inventory confirmation unavailable: $dir"
    fi
    return 1
  fi
  if "$reaper_command" "$action" "$dir"; then
    return 0
  fi
  if [[ "$action" == touch ]]; then
    # An initially ready project may be unmanaged; touch is deliberately a no-op.
    return 0
  fi
  if [[ "$action" == register ]]; then
    print -u2 "open-codex-project-in-pycharm: reaper $action failed; project ownership is ambiguous: $dir"
    return 1
  fi
}

open_new_pycharm_window() {
  local dir="$1"

  if [[ -d "$pycharm_app_path" && -x "$pycharm_open_command" ]]; then
    "$pycharm_open_command" -a "$pycharm_app_path" "$dir" >/dev/null 2>&1
    return 0
  fi

  if command -v pycharm >/dev/null 2>&1; then
    pycharm "$dir" >/dev/null 2>&1 &
    return 0
  fi

  if command -v charm >/dev/null 2>&1; then
    charm "$dir" >/dev/null 2>&1 &
    return 0
  fi

  if [[ -d /Applications/PyCharm.app ]]; then
    nohup /Applications/PyCharm.app/Contents/MacOS/pycharm "$dir" >/dev/null 2>&1 &
    return 0
  fi

  if [[ -d "$HOME/Applications/PyCharm.app" ]]; then
    nohup "$HOME/Applications/PyCharm.app/Contents/MacOS/pycharm" "$dir" >/dev/null 2>&1 &
    return 0
  fi

  return 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --require-github)
      require_github=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --*)
      usage
      print -u2 "open-codex-project-in-pycharm: unknown option: $1"
      exit 2
      ;;
    *)
      project_dir="$1"
      shift
      ;;
  esac
done

if [[ ! -d "$project_dir" ]]; then
  print -u2 "open-codex-project-in-pycharm: not a directory: $project_dir"
  exit 2
fi

project_dir="$(cd "$project_dir" && pwd -P)"
trap release_opener_lock EXIT INT TERM HUP

if [[ "$require_github" == true ]] && ! has_github_remote "$project_dir"; then
  print "open-codex-project-in-pycharm: skipped, no GitHub remote found for $project_dir"
  exit 0
fi

if is_open_in_pycharm "$project_dir"; then
  print "open-codex-project-in-pycharm: already open in PyCharm: $project_dir"
  update_reaper_registry touch "$project_dir" || exit 1
  exit 0
fi

acquire_opener_lock || exit 2

if is_open_in_pycharm "$project_dir"; then
  print "open-codex-project-in-pycharm: already open in PyCharm: $project_dir"
  update_reaper_registry touch "$project_dir" || exit 1
  exit 0
fi

if ! ensure_project_trusted "$project_dir"; then
  print -u2 "open-codex-project-in-pycharm: failed to trust project before opening: $project_dir"
  exit 1
fi

if open_new_pycharm_window "$project_dir"; then
  print "open-codex-project-in-pycharm: opened in a new PyCharm window: $project_dir"
  if wait_for_serena_service "$project_dir"; then
    update_reaper_registry register "$project_dir" || exit 1
    exit 0
  else
    ready_status=$?
    exit "$ready_status"
  fi
fi

print -u2 "open-codex-project-in-pycharm: PyCharm launcher or app bundle not found"
exit 1
