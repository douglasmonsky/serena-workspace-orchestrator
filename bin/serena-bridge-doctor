#!/usr/bin/env python3
"""Diagnose and repair the Codex-to-Serena task bridge without conflating layers."""

from __future__ import annotations

import argparse
from dataclasses import asdict
from datetime import datetime
import json
import os
from pathlib import Path
import shutil
import subprocess
import sys
from typing import Any, Sequence


SCRIPT_DIR = Path(__file__).resolve().parent
if str(SCRIPT_DIR) not in sys.path:
    sys.path.insert(0, str(SCRIPT_DIR))
import workspace_harbor_bridge as bridge  # noqa: E402
import workspace_harbor_codex as codex  # noqa: E402


CODEX_HOME = Path(os.environ.get("CODEX_HOME", Path.home() / ".codex"))
BROKER = Path(
    os.environ.get(
        "WORKSPACE_HARBOR_BROKER",
        CODEX_HOME / "bin" / "serena-worktree-broker",
    )
)
PROJECT_DOCTOR = Path(
    os.environ.get(
        "WORKSPACE_HARBOR_PROJECT_DOCTOR",
        CODEX_HOME / "bin" / "serena-project-doctor",
    )
)
BRIDGE_STATE = Path(
    os.environ.get(
        "WORKSPACE_HARBOR_BRIDGE_STATE",
        CODEX_HOME / "state" / "serena-bridge",
    )
)
INCIDENTS = BRIDGE_STATE / "incidents"
ATTESTATIONS = BRIDGE_STATE / "attestations"
CHECKPOINTS = BRIDGE_STATE / "checkpoints"
RELAUNCHER = Path(
    os.environ.get(
        "WORKSPACE_HARBOR_CODEX_RELAUNCHER",
        CODEX_HOME / "bin" / "workspace-harbor-codex-relauncher",
    )
)
SUBPROCESS_TIMEOUT_SECONDS = 45


def _resolve_codex_cli() -> Path:
    configured = os.environ.get("WORKSPACE_HARBOR_CODEX_CLI")
    if configured:
        return Path(configured).expanduser()
    bundled = Path("/Applications/ChatGPT.app/Contents/Resources/codex")
    if bundled.is_file():
        return bundled
    discovered = shutil.which("codex")
    return Path(discovered) if discovered else Path("/missing/codex")


def _run_json(command: Sequence[str], *, timeout: float) -> Any:
    try:
        completed = subprocess.run(
            list(command),
            capture_output=True,
            text=True,
            timeout=timeout,
            check=False,
        )
    except subprocess.TimeoutExpired:
        return {"status": "unavailable", "reason": "command-timeout"}
    except OSError:
        return {"status": "unavailable", "reason": "command-failed"}
    if completed.returncode != 0:
        return {
            "status": "unavailable",
            "reason": f"command-exit-{completed.returncode}",
        }
    try:
        payload = json.loads(completed.stdout)
    except json.JSONDecodeError:
        return {"status": "unavailable", "reason": "invalid-json"}
    return payload


def _configuration() -> bridge.ConfigCheck:
    return bridge.check_codex_serena_config(_resolve_codex_cli(), BROKER)


def _project_report(root: Path, *, recover: bool) -> dict[str, Any]:
    command = [str(PROJECT_DOCTOR)]
    if recover:
        command.append("--recover")
    command.extend(("--json", str(root)))
    payload = _run_json(command, timeout=SUBPROCESS_TIMEOUT_SECONDS)
    return (
        payload
        if isinstance(payload, dict)
        else {"status": "unavailable", "reason": "invalid-json"}
    )


def _repair_broker(root: Path) -> dict[str, Any]:
    payload = _run_json(
        [str(BROKER), "repair-root", str(root), "--json"],
        timeout=15,
    )
    return (
        payload
        if isinstance(payload, dict)
        else {"status": "unavailable", "reason": "invalid-json"}
    )


def _broker_evidence(root: Path) -> dict[str, Any]:
    canonical = str(root.expanduser().resolve(strict=False))
    owner = _run_json([str(BROKER), "owner", "--json"], timeout=5)
    services = _run_json([str(BROKER), "status", "--json"], timeout=5)
    matching = []
    if isinstance(services, list):
        matching = [
            item
            for item in services
            if isinstance(item, dict) and item.get("project_root") == canonical
        ]
    return {
        "owner_source": (
            owner.get("source", "unknown") if isinstance(owner, dict) else "unknown"
        ),
        "owner_reason": (
            owner.get("reason") if isinstance(owner, dict) else "invalid-json"
        ),
        "matching_services": len(matching),
        "healthy_services": sum(item.get("healthy") is True for item in matching),
        "live_leases": sum(
            item.get("leases", 0)
            for item in matching
            if isinstance(item.get("leases", 0), int)
        ),
    }


def _handshake(root: Path) -> bridge.HandshakeResult:
    journal = bridge.BridgeJournal(BRIDGE_STATE)
    desktop_owner = bridge.find_desktop_host_owner(root, BROKER)
    environment = (
        {"WORKSPACE_HARBOR_OWNER_ID": desktop_owner}
        if desktop_owner is not None
        else None
    )
    return bridge.run_handshake(
        root,
        BROKER,
        journal=journal,
        extra_environment=environment,
    )


def _semantic_status(project: dict[str, Any]) -> str:
    semantic = project.get("jetbrains_semantic_health")
    if isinstance(semantic, dict):
        return str(semantic.get("status", "unknown"))
    return str(project.get("semantic_health", "unknown"))


def build_status(
    *,
    root: Path,
    reported_tools: str,
    config: bridge.ConfigCheck,
    project: dict[str, Any],
    handshake: bridge.HandshakeResult | None,
) -> dict[str, Any]:
    backend = (
        "backend-healthy"
        if _semantic_status(project) == "healthy"
        else "backend-unhealthy"
    )
    if handshake is None:
        handshake_state = "handshake-unverified"
    elif handshake.status == "healthy":
        handshake_state = "handshake-healthy"
    else:
        handshake_state = "handshake-unhealthy"
    exposure = f"task-tools-{reported_tools}"
    report: dict[str, Any] = {
        "status": "unknown",
        "reason": "unclassified",
        "root": str(root.expanduser().resolve(strict=False)),
        "backend": backend,
        "handshake": handshake_state,
        "task_exposure": exposure,
        "incident": None,
        "next_action": "inspect-bridge-status",
    }
    if config.status != "healthy":
        report.update(
            status="configuration-invalid",
            reason=f"config-{config.reason}",
            next_action="repair-codex-config",
        )
    elif backend != "backend-healthy":
        report.update(
            status="backend-unhealthy",
            reason=f"semantic-{_semantic_status(project)}",
            next_action="recover-serena-project",
        )
    elif handshake_state == "handshake-unhealthy":
        assert handshake is not None
        report.update(
            status="handshake-unhealthy",
            reason=handshake.reason,
            next_action="repair-harbor-state",
        )
    elif handshake_state == "handshake-unverified":
        report.update(
            status="handshake-unverified",
            reason="probe-not-run",
            next_action="run-bridge-probe",
        )
    elif reported_tools == "missing":
        report.update(
            status="restart-eligible",
            reason="handshake-healthy-task-tools-missing",
            next_action="prepare-guarded-restart",
        )
    elif reported_tools == "unknown":
        report.update(
            status="exposure-unverified",
            reason="task-tools-not-reported",
            next_action="report-task-tool-exposure",
        )
    else:
        report.update(
            status="healthy",
            reason="all-layers-healthy",
            next_action="none",
        )
    return report


def status_bridge(
    root: Path,
    *,
    reported_tools: str,
    probe: bool,
) -> dict[str, Any]:
    canonical = root.expanduser().resolve()
    config = _configuration()
    project = _project_report(canonical, recover=False)
    handshake = _handshake(canonical) if probe else None
    report = build_status(
        root=canonical,
        reported_tools=reported_tools,
        config=config,
        project=project,
        handshake=handshake,
    )
    report["config"] = {"status": config.status, "reason": config.reason}
    report["project_semantics"] = _semantic_status(project)
    report["broker"] = _broker_evidence(canonical)
    report["recent_events"] = bridge.BridgeJournal(BRIDGE_STATE).recent(
        canonical, limit=12
    )
    if handshake is not None:
        report["probe"] = {
            key: value
            for key, value in asdict(handshake).items()
            if key != "process_pid"
        }
    return report


def _repaired_report(report: dict[str, Any]) -> dict[str, Any]:
    updated = dict(report)
    updated.update(
        status="harbor-repaired",
        reason="lower-layer-repaired",
        incident=None,
        next_action="recheck-task-tools",
    )
    return updated


def recover_bridge(
    root: Path,
    *,
    reported_tools: str,
    thread_id: str,
    store: bridge.IncidentStore | None = None,
) -> dict[str, Any]:
    canonical = root.expanduser().resolve()
    if reported_tools != "missing":
        return {
            "status": "invalid-state",
            "reason": "recover-requires-missing-tools",
            "root": str(canonical),
            "next_action": "run-status",
        }
    incident_store = store or bridge.IncidentStore(INCIDENTS)
    config = _configuration()
    if config.status != "healthy":
        return build_status(
            root=canonical,
            reported_tools=reported_tools,
            config=config,
            project={"semantic_health": "unknown"},
            handshake=None,
        )
    project = _project_report(canonical, recover=False)
    project_changed = False
    if _semantic_status(project) != "healthy":
        project = _project_report(canonical, recover=True)
        project_changed = True
        if _semantic_status(project) != "healthy":
            return build_status(
                root=canonical,
                reported_tools=reported_tools,
                config=config,
                project=project,
                handshake=None,
            )
    handshake = _handshake(canonical)
    if project_changed and handshake.status == "healthy":
        return _repaired_report(
            build_status(
                root=canonical,
                reported_tools=reported_tools,
                config=config,
                project=project,
                handshake=handshake,
            )
        )
    if handshake.status != "healthy":
        repair = _repair_broker(canonical)
        if repair.get("status") != "repaired":
            return build_status(
                root=canonical,
                reported_tools=reported_tools,
                config=config,
                project=project,
                handshake=handshake,
            )
        handshake = _handshake(canonical)
        if handshake.status == "healthy":
            return _repaired_report(
                build_status(
                    root=canonical,
                    reported_tools=reported_tools,
                    config=config,
                    project=project,
                    handshake=handshake,
                )
            )
    report = build_status(
        root=canonical,
        reported_tools=reported_tools,
        config=config,
        project=project,
        handshake=handshake,
    )
    if report["status"] == "restart-eligible":
        if not thread_id:
            report.update(
                status="restart-blocked",
                reason="thread-id-missing",
                next_action="provide-thread-id",
            )
            return report
        incident = incident_store.create_or_reuse_restart(
            canonical, thread_id, "task-tools-missing"
        )
        report["incident"] = incident.id
    return report


def attestation_path(state_dir: Path, incident_id: str) -> Path:
    return state_dir / "attestations" / f"{incident_id}.json"


def checkpoint_path(state_dir: Path, incident_id: str) -> Path:
    return state_dir / "checkpoints" / f"{incident_id}.json"


def _incident_matches(
    incident: bridge.BridgeIncident,
    root: Path,
    current_thread: str,
) -> bool:
    return (
        incident.root == str(root.expanduser().resolve(strict=False))
        and incident.thread_id == current_thread
    )


def attest_restart(
    root: Path,
    *,
    incident_id: str,
    current_thread: str,
    host_id: str,
    active_threads: Sequence[str],
    active_children: Sequence[str],
    unknown_threads: Sequence[str],
    unavailable_hosts: Sequence[str],
    observed_at,
    heartbeat: dict[str, Any],
    store: bridge.IncidentStore | None = None,
    state_dir: Path = BRIDGE_STATE,
) -> dict[str, Any]:
    incident_store = store or bridge.IncidentStore(state_dir / "incidents")
    incident = incident_store.load(incident_id)
    if incident.state != "restart-eligible" or not _incident_matches(
        incident, root, current_thread
    ):
        return {
            "status": "invalid-state",
            "reason": "incident-not-restart-eligible",
            "next_action": "run-bridge-recover",
        }
    try:
        attestation = codex.build_restart_attestation(
            current_thread=current_thread,
            host_id=host_id,
            active_threads=active_threads,
            active_children=active_children,
            unknown_threads=unknown_threads,
            unavailable_hosts=unavailable_hosts,
            observed_at=observed_at,
            heartbeat=heartbeat,
            incident=incident_id,
        )
    except codex.AttestationError as error:
        return {
            "status": "restart-refused",
            "reason": error.reason,
            "next_action": "keep-current-task-running",
        }
    path = attestation_path(state_dir, incident_id)
    codex.write_private_dataclass(path, attestation)
    return {
        "status": "restart-attested",
        "reason": "exclusive-task-heartbeat-verified",
        "incident": incident_id,
        "next_action": "prepare-restart",
    }


def _launch_relauncher(path: Path, state_dir: Path) -> bool:
    log_path = state_dir / "relauncher.log"
    log_path.parent.mkdir(parents=True, exist_ok=True, mode=0o700)
    descriptor = os.open(log_path, os.O_WRONLY | os.O_CREAT | os.O_APPEND, 0o600)
    try:
        with os.fdopen(descriptor, "a", encoding="utf-8") as stream:
            subprocess.Popen(
                [str(RELAUNCHER), str(path)],
                stdin=subprocess.DEVNULL,
                stdout=stream,
                stderr=stream,
                start_new_session=True,
                close_fds=True,
            )
    except OSError:
        return False
    return True


def prepare_restart(
    root: Path,
    *,
    incident_id: str,
    current_thread: str,
    dogfood: bool,
    store: bridge.IncidentStore | None = None,
    state_dir: Path = BRIDGE_STATE,
    now=None,
) -> dict[str, Any]:
    from datetime import datetime, timezone

    incident_store = store or bridge.IncidentStore(state_dir / "incidents")
    try:
        incident = incident_store.load(incident_id)
    except (OSError, ValueError):
        return {"status": "invalid-state", "reason": "incident-missing"}
    if incident.state != "restart-eligible":
        return {
            "status": "invalid-state",
            "reason": "restart-budget-exhausted",
            "next_action": "keep-current-task-running",
        }
    if not _incident_matches(incident, root, current_thread):
        return {"status": "invalid-state", "reason": "incident-scope-mismatch"}
    proof_path = attestation_path(state_dir, incident_id)
    try:
        attestation = codex.load_restart_attestation(proof_path)
        codex.validate_restart_attestation(
            attestation,
            current_thread=current_thread,
            incident=incident_id,
            now=now or datetime.now(timezone.utc),
        )
    except (OSError, ValueError, json.JSONDecodeError, codex.AttestationError) as error:
        reason = (
            error.reason
            if isinstance(error, codex.AttestationError)
            else "attestation-missing"
        )
        return {
            "status": "restart-blocked",
            "reason": reason,
            "next_action": "refresh-restart-attestation",
        }
    policy = codex.RestartPolicyStore(state_dir / "config.json").load()
    if not dogfood and not policy["automatic_codex_restart"]:
        return {
            "status": "restart-blocked",
            "reason": "restart-policy-disabled",
            "next_action": "use-dogfood-or-enable-after-success",
        }
    identity = codex.find_codex_app_identity()
    if identity is None:
        return {
            "status": "restart-blocked",
            "reason": "codex-identity-unavailable",
            "next_action": "keep-current-task-running",
        }
    checkpoint = codex.RelaunchCheckpoint(
        incident_id=incident.id,
        incident_store=str(incident_store.state_dir),
        root=incident.root,
        thread_id=current_thread,
        heartbeat_id=attestation.heartbeat_id,
        attestation_nonce=attestation.nonce,
        doctor_pid=os.getpid(),
        app_identity=identity,
        created_at=(now or datetime.now(timezone.utc)).isoformat(),
    )
    incident_store.transition(
        incident.id,
        "restart-eligible",
        "restart-prepared",
        reason="restart-prepared",
        restart_attempted=True,
        heartbeat_id=attestation.heartbeat_id,
        dogfood_restart=dogfood,
    )
    path = checkpoint_path(state_dir, incident.id)
    try:
        codex.write_private_dataclass(path, checkpoint)
        launched = _launch_relauncher(path, state_dir)
    except OSError:
        launched = False
    if not launched:
        incident_store.transition(
            incident.id,
            "restart-prepared",
            "closed-blocked",
            reason="relauncher-launch-failed",
        )
        return {"status": "restart-blocked", "reason": "relauncher-launch-failed"}
    return {
        "status": "restart-prepared",
        "reason": "graceful-relaunch-scheduled",
        "incident": incident.id,
        "heartbeat_id": attestation.heartbeat_id,
        "next_action": "exit-for-relauncher",
    }


def resume_bridge(
    root: Path,
    *,
    incident_id: str,
    current_thread: str,
    reported_tools: str,
    store: bridge.IncidentStore | None = None,
    state_dir: Path = BRIDGE_STATE,
) -> dict[str, Any]:
    incident_store = store or bridge.IncidentStore(state_dir / "incidents")
    incident = incident_store.load(incident_id)
    if incident.state != "resume-pending":
        return {
            "status": "invalid-state",
            "reason": "restart-budget-exhausted",
            "heartbeat_id": incident.heartbeat_id,
        }
    if not _incident_matches(incident, root, current_thread):
        return {"status": "invalid-state", "reason": "incident-scope-mismatch"}
    try:
        checkpoint = codex.load_checkpoint(checkpoint_path(state_dir, incident.id))
    except (OSError, ValueError, json.JSONDecodeError):
        return {"status": "invalid-state", "reason": "checkpoint-missing"}
    current_identity = codex.find_codex_app_identity()
    if current_identity is None or current_identity == checkpoint.app_identity:
        return {"status": "invalid-state", "reason": "codex-not-relaunched"}
    handshake = _handshake(root.expanduser().resolve())
    if handshake.status != "healthy" or reported_tools == "missing":
        closed = incident_store.transition(
            incident.id,
            "resume-pending",
            "closed-fresh-task-required",
            reason=(
                "post-restart-handshake-failed"
                if handshake.status != "healthy"
                else "task-tools-still-missing"
            ),
        )
        return {
            "status": "fresh-task-required",
            "reason": closed.reason,
            "incident": incident.id,
            "heartbeat_id": incident.heartbeat_id,
        }
    closed = incident_store.transition(
        incident.id,
        "resume-pending",
        "closed-healthy",
        reason="task-tools-restored",
    )
    return {
        "status": "healthy",
        "reason": closed.reason,
        "incident": incident.id,
        "heartbeat_id": incident.heartbeat_id,
    }


def update_restart_policy(
    action: str,
    *,
    incident_id: str | None,
    store: bridge.IncidentStore | None = None,
    policy: codex.RestartPolicyStore | None = None,
) -> dict[str, Any]:
    policy_store = policy or codex.RestartPolicyStore(BRIDGE_STATE / "config.json")
    if action == "status":
        return {"status": "restart-policy", **policy_store.load()}
    if action == "disable":
        return {"status": "restart-policy", **policy_store.write(False)}
    if not incident_id:
        return {"status": "restart-policy-blocked", "reason": "incident-required"}
    incident_store = store or bridge.IncidentStore(INCIDENTS)
    try:
        incident = incident_store.load(incident_id)
    except (OSError, ValueError):
        return {"status": "restart-policy-blocked", "reason": "incident-missing"}
    if incident.state != "closed-healthy" or not incident.dogfood_restart:
        return {
            "status": "restart-policy-blocked",
            "reason": "successful-dogfood-required",
        }
    return {"status": "restart-policy", **policy_store.write(True)}


def _parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description=__doc__)
    subparsers = parser.add_subparsers(dest="command", required=True)
    for name in ("status", "recover"):
        command = subparsers.add_parser(name)
        command.add_argument("root")
        command.add_argument(
            "--reported-tools",
            choices=("present", "missing", "unknown"),
            required=True,
        )
        command.add_argument("--json", action="store_true")
        if name == "status":
            command.add_argument("--probe", action="store_true")
        else:
            command.add_argument(
                "--thread-id", default=os.environ.get("CODEX_THREAD_ID", "")
            )
    attest = subparsers.add_parser("attest-restart")
    attest.add_argument("root")
    attest.add_argument("--incident", required=True)
    attest.add_argument("--thread-id", required=True)
    attest.add_argument("--host-id", required=True)
    attest.add_argument("--active-thread", action="append", default=[])
    attest.add_argument("--active-child", action="append", default=[])
    attest.add_argument("--unknown-thread", action="append", default=[])
    attest.add_argument("--unavailable-host", action="append", default=[])
    attest.add_argument("--observed-at", required=True)
    attest.add_argument("--heartbeat-id", required=True)
    attest.add_argument("--heartbeat-target", required=True)
    attest.add_argument("--heartbeat-next-run", required=True)
    attest.add_argument("--heartbeat-enabled", action="store_true")
    attest.add_argument("--json", action="store_true")
    prepare = subparsers.add_parser("prepare-restart")
    prepare.add_argument("root")
    prepare.add_argument("--incident", required=True)
    prepare.add_argument("--thread-id", required=True)
    prepare.add_argument("--dogfood", action="store_true")
    prepare.add_argument("--json", action="store_true")
    resume = subparsers.add_parser("resume")
    resume.add_argument("root")
    resume.add_argument("--incident", required=True)
    resume.add_argument("--thread-id", required=True)
    resume.add_argument(
        "--reported-tools", choices=("present", "missing"), required=True
    )
    resume.add_argument("--json", action="store_true")
    policy = subparsers.add_parser("restart-policy")
    policy.add_argument("action", choices=("status", "enable", "disable"))
    policy.add_argument("--incident")
    policy.add_argument("--json", action="store_true")
    return parser


def _print_human(report: dict[str, Any]) -> None:
    print(report["status"])
    print(f"Next action: {report.get('next_action', 'inspect-bridge-status')}")


def main(argv: Sequence[str] | None = None) -> int:
    args = _parser().parse_args(argv)
    try:
        if args.command == "status":
            report = status_bridge(
                Path(args.root),
                reported_tools=args.reported_tools,
                probe=args.probe,
            )
        elif args.command == "recover":
            report = recover_bridge(
                Path(args.root),
                reported_tools=args.reported_tools,
                thread_id=args.thread_id,
            )
        elif args.command == "attest-restart":
            report = attest_restart(
                Path(args.root),
                incident_id=args.incident,
                current_thread=args.thread_id,
                host_id=args.host_id,
                active_threads=args.active_thread,
                active_children=args.active_child,
                unknown_threads=args.unknown_thread,
                unavailable_hosts=args.unavailable_host,
                observed_at=datetime.fromisoformat(args.observed_at),
                heartbeat={
                    "id": args.heartbeat_id,
                    "target_thread_id": args.heartbeat_target,
                    "enabled": args.heartbeat_enabled,
                    "next_run": datetime.fromisoformat(args.heartbeat_next_run),
                    "incident": args.incident,
                },
            )
        elif args.command == "prepare-restart":
            report = prepare_restart(
                Path(args.root),
                incident_id=args.incident,
                current_thread=args.thread_id,
                dogfood=args.dogfood,
            )
        elif args.command == "resume":
            report = resume_bridge(
                Path(args.root),
                incident_id=args.incident,
                current_thread=args.thread_id,
                reported_tools=args.reported_tools,
            )
        else:
            report = update_restart_policy(
                args.action,
                incident_id=args.incident,
            )
    except (OSError, RuntimeError, ValueError, subprocess.SubprocessError) as error:
        report = {
            "status": "unavailable",
            "reason": "doctor-failed",
            "next_action": "inspect-local-state",
        }
        if os.environ.get("WORKSPACE_HARBOR_DEBUG") == "1":
            report["debug_type"] = type(error).__name__
    if args.json:
        print(json.dumps(report, indent=2, sort_keys=True))
    else:
        _print_human(report)
    success = {
        "healthy",
        "harbor-repaired",
        "restart-attested",
        "restart-prepared",
        "restart-policy",
    }
    return 0 if report["status"] in success else 1


if __name__ == "__main__":
    raise SystemExit(main())
