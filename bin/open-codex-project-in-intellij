#!/usr/bin/env zsh
set -eu
setopt extendedglob

require_github=false
project_dir="$PWD"
intellij_app_path="${INTELLIJ_APP_PATH:-$HOME/Applications/IntelliJ IDEA.app}"
intellij_open_command="${INTELLIJ_OPEN_COMMAND:-/usr/bin/open}"
ready_interval="${INTELLIJ_SERENA_READY_INTERVAL:-1}"
ready_timeout="${INTELLIJ_SERENA_READY_TIMEOUT:-120}"
opener_state_dir="${INTELLIJ_OPENER_STATE_DIR:-$HOME/.codex/state/intellij-projects}"
opener_lock_dir="$opener_state_dir/opener.lock"
coordinator_command="${WORKSPACE_HARBOR_OPENER_QUEUE_COMMAND:-$HOME/.codex/bin/workspace_harbor_opener_queue.py}"
operation_allowance="${INTELLIJ_OPENER_OPERATION_TIMEOUT:-300}"
queue_allowance="${INTELLIJ_OPENER_QUEUE_TIMEOUT:-300}"
launch_command_timeout="${INTELLIJ_OPENER_LAUNCH_COMMAND_TIMEOUT:-30}"
reaper_command="${INTELLIJ_PROJECT_REAPER_COMMAND:-$HOME/.codex/bin/intellij-project-reaper}"
model_ready_command="${INTELLIJ_MODEL_READY_COMMAND:-$reaper_command}"
project_trust_command="${INTELLIJ_PROJECT_TRUST_COMMAND:-$HOME/.codex/bin/intellij-project-trust}"
bootstrap_command="${WORKSPACE_HARBOR_BOOTSTRAP_COMMAND:-$HOME/.codex/bin/workspace-harbor-bootstrap}"
bootstrap_opener_timeout="${WORKSPACE_HARBOR_BOOTSTRAP_OPENER_TIMEOUT_SECONDS:-1860}"
coordinator_active=false
launch_claimed=false
request_id=""
owner_started=""
overall_deadline=""

usage() {
  print -u2 "Usage: open-codex-project-in-intellij [--require-github] [PROJECT_DIR]"
}

has_github_remote() {
  local dir="$1"

  git -C "$dir" rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 1
  git -C "$dir" remote -v 2>/dev/null | grep -Eq 'github\.com[:/]'
}

is_open_in_intellij() {
  local dir="$1"

  "$HOME/.codex/bin/serena-codex" jetbrains-service-status "$dir" >/dev/null 2>&1
}

is_model_ready() {
  local dir="$1"

  [[ -x "$model_ready_command" ]] || return 1
  "$model_ready_command" model-ready "$dir" >/dev/null 2>&1
}

is_ready_in_intellij() {
  local dir="$1"

  is_open_in_intellij "$dir" && is_model_ready "$dir"
}

launch_command_budget() {
  local remaining
  zmodload zsh/datetime
  remaining=$(( overall_deadline - EPOCHREALTIME ))
  (( remaining > 0 )) || return 1
  if (( remaining < launch_command_timeout )); then
    print -r -- "$remaining"
  else
    print -r -- "$launch_command_timeout"
  fi
}

run_command_bounded() {
  local timeout="$1"
  shift
  python3 - "$timeout" "$@" <<'PY'
import math
import os
import signal
import subprocess
import sys

try:
    timeout = float(sys.argv[1])
except ValueError:
    raise SystemExit(2)
if not math.isfinite(timeout) or timeout <= 0:
    raise SystemExit(2)
try:
    process = subprocess.Popen(
        sys.argv[2:],
        stdin=subprocess.DEVNULL,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )
except OSError:
    raise SystemExit(1)
try:
    raise SystemExit(process.wait(timeout=timeout))
except subprocess.TimeoutExpired:
    pass
for group_signal, grace in ((signal.SIGTERM, 0.5), (signal.SIGKILL, 0.5)):
    try:
        os.killpg(process.pid, group_signal)
    except ProcessLookupError:
        break
    try:
        process.wait(timeout=grace)
        break
    except subprocess.TimeoutExpired:
        continue
raise SystemExit(124)
PY
}

ensure_project_trusted() {
  local dir="$1" timeout

  [[ -x "$project_trust_command" ]] || return 1
  timeout="$(launch_command_budget)" || return 1
  run_command_bounded "$timeout" "$project_trust_command" allow "$dir"
}

format_bootstrap_diagnostic() {
  local result_code="$1"

  if ! command -v python3 >/dev/null 2>&1; then
    print -r -- "exit=$result_code; diagnostic-parser=unavailable"
    return 0
  fi
  python3 -c '
import json
import sys

exit_code = sys.argv[1]
try:
    result = json.load(sys.stdin)
except (json.JSONDecodeError, OSError, TypeError, ValueError):
    print(f"exit={exit_code}; result=unreadable")
    raise SystemExit(0)
if not isinstance(result, dict):
    print(f"exit={exit_code}; result=unreadable")
    raise SystemExit(0)
parts = [f"exit={exit_code}"]
for key in ("status", "failure_kind", "operation"):
    value = result.get(key)
    if isinstance(value, str):
        parts.append(f"{key}={value}")
detail = result.get("error") or result.get("failure_context")
if isinstance(detail, str) and detail:
    parts.append("detail=" + " ".join(detail.split()))
encoded = "; ".join(parts).encode("utf-8")
if len(encoded) > 512:
    encoded = encoded[:509].decode("utf-8", errors="ignore").encode("utf-8") + b"..."
print(encoded.decode("utf-8", errors="ignore"))
' "$result_code"
}

run_bootstrap_bounded() {
  local dir="$1"

  if ! command -v python3 >/dev/null 2>&1; then
    print -r -- '{"status":"failed","failure_kind":"runtime-unavailable","operation":"bootstrap-opener","error":"python3 unavailable for bounded bootstrap"}'
    return 124
  fi
  python3 - "$bootstrap_opener_timeout" "$bootstrap_command" "$dir" <<'PY'
import json
import math
import os
import selectors
import signal
import subprocess
import sys
import time

try:
    timeout = float(sys.argv[1])
except (TypeError, ValueError):
    timeout = 0
if not math.isfinite(timeout) or timeout <= 0:
    print(json.dumps({
        "status": "failed",
        "failure_kind": "invalid-timeout",
        "operation": "bootstrap-opener",
        "error": "bootstrap opener timeout must be a positive finite number",
    }))
    raise SystemExit(124)

command = [sys.argv[2], "run", sys.argv[3], "--json"]
BOOTSTRAP_OUTPUT_LIMIT_BYTES = 65536
output_tail = bytearray()
try:
    process = subprocess.Popen(
        command,
        stdin=subprocess.DEVNULL,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        start_new_session=True,
    )
except OSError as error:
    print(json.dumps({
        "status": "failed",
        "failure_kind": "process-error",
        "operation": "bootstrap-opener",
        "error": str(error),
    }))
    raise SystemExit(127)

assert process.stdout is not None
pipe = process.stdout
os.set_blocking(pipe.fileno(), False)
selector = selectors.DefaultSelector()
selector.register(pipe, selectors.EVENT_READ)
pipe_open = True

def drain_once(wait_seconds):
    global pipe_open
    if not pipe_open:
        time.sleep(max(0, wait_seconds))
        return
    for key, _ in selector.select(max(0, wait_seconds)):
        while True:
            try:
                chunk = os.read(key.fd, 65536)
            except BlockingIOError:
                break
            if not chunk:
                pipe_open = False
                selector.unregister(pipe)
                return
            output_tail.extend(chunk)
            excess = len(output_tail) - BOOTSTRAP_OUTPUT_LIMIT_BYTES
            if excess > 0:
                del output_tail[:excess]

def drain_until(deadline):
    while pipe_open and time.monotonic() < deadline:
        drain_once(min(0.05, deadline - time.monotonic()))

def signal_group(group_signal):
    try:
        os.killpg(process.pid, group_signal)
        return True
    except ProcessLookupError:
        return False

def stop_remaining_group():
    if not signal_group(signal.SIGTERM):
        return
    deadline = time.monotonic() + 5
    while (process.poll() is None or pipe_open) and time.monotonic() < deadline:
        drain_once(min(0.05, deadline - time.monotonic()))
    if process.poll() is None or pipe_open:
        signal_group(signal.SIGKILL)
        deadline = time.monotonic() + 5
        while (process.poll() is None or pipe_open) and time.monotonic() < deadline:
            drain_once(min(0.05, deadline - time.monotonic()))

deadline = time.monotonic() + timeout
while process.poll() is None and time.monotonic() < deadline:
    drain_once(min(0.05, deadline - time.monotonic()))
timed_out = process.poll() is None
if timed_out:
    stop_remaining_group()
    if process.poll() is None:
        try:
            process.wait(timeout=0.1)
        except subprocess.TimeoutExpired:
            pass
else:
    return_code = process.returncode
    stop_remaining_group()
drain_until(time.monotonic() + 0.5)
selector.close()
pipe.close()

if timed_out:
    print(json.dumps({
        "status": "failed",
        "failure_kind": "timeout",
        "operation": "bootstrap-opener",
        "error": f"dependency bootstrap exceeded {timeout:g}s",
    }))
    raise SystemExit(124)
sys.stdout.buffer.write(bytes(output_tail))
raise SystemExit(return_code)
PY
}

prepare_project_dependencies() {
  local dir="$1" result_code result_payload diagnostic category

  if [[ ! -x "$bootstrap_command" ]]; then
    print -u2 "open-codex-project-in-intellij: dependency bootstrap command unavailable; continuing with IntelliJ and Serena"
    return 0
  fi
  if result_payload="$(run_bootstrap_bounded "$dir" 2>&1)"; then
    return 0
  else
    result_code=$?
  fi
  diagnostic="$(print -rn -- "$result_payload" | format_bootstrap_diagnostic "$result_code")"
  case "$result_code" in
    1) category="is degraded" ;;
    2) category="validation failed" ;;
    3) category="needs a repository decision" ;;
    124) category="timed out" ;;
    *) category="returned an unexpected result" ;;
  esac
  print -u2 "open-codex-project-in-intellij: dependency bootstrap $category ($diagnostic); continuing with IntelliJ and Serena available for diagnosis"
  return 0
}

json_field() {
  local packet="$1" field="$2"
  python3 -c '
import json
import sys
value = json.loads(sys.argv[1]).get(sys.argv[2])
if value is True:
    print("true")
elif value is False:
    print("false")
elif value is not None:
    print(value)
' "$packet" "$field"
}

run_coordinator() {
  python3 "$coordinator_command" "$@"
}

emit_result() {
  local result_status="$1" phase="$2" maximum_position="${3:-0}"
  local queue_wait="${4:-0}" launch_seconds="${5:-0}"
  python3 -c '
import json
import sys
packet = {
    "status": sys.argv[1],
    "phase": sys.argv[2],
    "maximum_queue_position": int(float(sys.argv[3])),
    "queue_wait_seconds": round(float(sys.argv[4]), 6),
    "launch_seconds": round(float(sys.argv[5]), 6),
}
print("WORKSPACE_HARBOR_RESULT " + json.dumps(packet, sort_keys=True, separators=(",", ":")))
' "$result_status" "$phase" "$maximum_position" "$queue_wait" "$launch_seconds"
}

release_launch_claim() {
  local release_packet release_exit
  [[ "$launch_claimed" == true ]] || return 0
  if release_packet="$(run_coordinator launch-release \
      --request-id "$request_id" --owner-pid "$$" --owner-start "$owner_started")"; then
    launch_claimed=false
    return 0
  fi
  release_exit=$?
  fail_from_packet "$release_packet" "$release_exit"
}

cleanup_coordination() {
  release_launch_claim >/dev/null 2>&1 || true
  if [[ "$coordinator_active" == true ]]; then
    run_coordinator release-all \
      --request-id "$request_id" --owner-pid "$$" --owner-start "$owner_started" \
      >/dev/null 2>&1 || true
    coordinator_active=false
  fi
}

fail_from_packet() {
  local packet="$1" exit_code="$2" phase error
  phase="$(json_field "$packet" phase 2>/dev/null || print state-invalid)"
  error="$(json_field "$packet" error 2>/dev/null || print 'coordination failed')"
  print -u2 "open-codex-project-in-intellij: ${phase}: ${error}"
  emit_result failed "$phase"
  return "$exit_code"
}

wait_for_serena_service() {
  local dir="$1"
  local deadline ready_deadline

  zmodload zsh/datetime
  ready_deadline=$(( EPOCHREALTIME + ready_timeout ))
  deadline="$ready_deadline"
  if [[ -n "$overall_deadline" ]] && (( overall_deadline < ready_deadline )); then
    deadline="$overall_deadline"
  fi
  while (( EPOCHREALTIME < deadline )); do
    if is_ready_in_intellij "$dir"; then
      print "open-codex-project-in-intellij: Serena service and native project model ready: $dir"
      return 0
    fi
    sleep "$ready_interval"
  done

  print -u2 "open-codex-project-in-intellij: readiness-deadline after ${ready_timeout}s: $dir"
  return 1
}

update_reaper_registry() {
  local action="$1" dir="$2" confirmation
  [[ -x "$reaper_command" ]] || return 0
  if "$reaper_command" is-open "$dir"; then
    confirmation=0
  else
    confirmation=$?
  fi
  if [[ "$confirmation" -ne 0 ]]; then
    if [[ "$action" == touch && "$confirmation" -eq 1 ]]; then
      # An already-ready root can be unmanaged; do not create ownership for it.
      return 0
    fi
    if [[ "$confirmation" -eq 1 ]]; then
      print -u2 "open-codex-project-in-intellij: reaper reports root not present in IntelliJ inventory: $dir"
    else
      print -u2 "open-codex-project-in-intellij: reaper inventory confirmation unavailable: $dir"
    fi
    return 1
  fi
  if "$reaper_command" "$action" "$dir"; then
    return 0
  fi
  if [[ "$action" == touch ]]; then
    # An initially ready project may be unmanaged; touch is deliberately a no-op.
    return 0
  fi
  if [[ "$action" == register ]]; then
    print -u2 "open-codex-project-in-intellij: reaper $action failed; project ownership is ambiguous: $dir"
    return 1
  fi
}

open_new_intellij_window() {
  local dir="$1" timeout

  if [[ -d "$intellij_app_path" && -x "$intellij_open_command" ]]; then
    timeout="$(launch_command_budget)" || return 1
    run_command_bounded "$timeout" \
      "$intellij_open_command" -a "$intellij_app_path" "$dir"
    return 0
  fi

  return 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --require-github)
      require_github=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --*)
      usage
      print -u2 "open-codex-project-in-intellij: unknown option: $1"
      exit 2
      ;;
    *)
      project_dir="$1"
      shift
      ;;
  esac
done

if [[ ! -d "$project_dir" ]]; then
  print -u2 "open-codex-project-in-intellij: not a directory: $project_dir"
  exit 2
fi

project_dir="$(cd "$project_dir" && pwd -P)"
trap cleanup_coordination EXIT
trap 'cleanup_coordination; exit 130' INT
trap 'cleanup_coordination; exit 143' TERM
trap 'cleanup_coordination; exit 129' HUP

if [[ "$require_github" == true ]] && ! has_github_remote "$project_dir"; then
  print "open-codex-project-in-intellij: skipped, no GitHub remote found for $project_dir"
  exit 0
fi

if prepare_project_dependencies "$project_dir"; then
  :
else
  bootstrap_status=$?
  exit "$bootstrap_status"
fi

if is_ready_in_intellij "$project_dir"; then
  print "open-codex-project-in-intellij: already open in IntelliJ: $project_dir"
  update_reaper_registry touch "$project_dir" || exit 1
  emit_result ready ready
  exit 0
fi

if [[ ! -f "$coordinator_command" ]]; then
  print -u2 "open-codex-project-in-intellij: opener coordinator is unavailable: $coordinator_command"
  emit_result failed state-invalid
  exit 2
fi

zmodload zsh/datetime
request_id="$(python3 -c 'import uuid; print(uuid.uuid4())')"
owner_started="$(ps -p $$ -o lstart= | sed 's/^ *//;s/ *$//')"
overall_deadline=$(( EPOCHREALTIME + operation_allowance + queue_allowance + ready_timeout ))

while true; do
  if migration_packet="$(run_coordinator migrate-legacy "$opener_lock_dir")"; then
    migration_status="$(json_field "$migration_packet" status)"
  else
    migration_exit=$?
    fail_from_packet "$migration_packet" "$migration_exit"
    exit $?
  fi
  [[ "$migration_status" == live ]] || break
  if (( EPOCHREALTIME >= overall_deadline )); then
    print -u2 "open-codex-project-in-intellij: operation-deadline waiting for legacy opener owner"
    emit_result failed operation-deadline
    exit 1
  fi
  sleep 0.1
done

if operation_packet="$(run_coordinator operation-acquire "$project_dir" \
    --request-id "$request_id" --owner-pid "$$" --owner-start "$owner_started" \
    --deadline "$overall_deadline")"; then
  coordinator_active=true
else
  operation_exit=$?
  fail_from_packet "$operation_packet" "$operation_exit"
  exit $?
fi

if [[ "$(json_field "$operation_packet" joined)" == true ]]; then
  print "open-codex-project-in-intellij: joined existing worktree open; wait=$(json_field "$operation_packet" wait_seconds)s"
fi

if is_ready_in_intellij "$project_dir"; then
  print "open-codex-project-in-intellij: already open in IntelliJ: $project_dir"
  update_reaper_registry touch "$project_dir" || exit 1
  emit_result ready ready
  exit 0
fi

if launch_packet="$(run_coordinator launch-acquire "$project_dir" \
    --request-id "$request_id" --owner-pid "$$" --owner-start "$owner_started" \
    --deadline "$overall_deadline")"; then
  launch_claimed=true
else
  launch_exit=$?
  fail_from_packet "$launch_packet" "$launch_exit"
  exit $?
fi
queue_wait="$(json_field "$launch_packet" wait_seconds)"
maximum_position="$(json_field "$launch_packet" maximum_position)"
launch_started="$EPOCHREALTIME"

if is_ready_in_intellij "$project_dir"; then
  release_launch_claim
  print "open-codex-project-in-intellij: already open in IntelliJ: $project_dir"
  update_reaper_registry touch "$project_dir" || exit 1
  emit_result ready ready "$maximum_position" "$queue_wait" 0
  exit 0
fi

if ! ensure_project_trusted "$project_dir"; then
  release_launch_claim
  print -u2 "open-codex-project-in-intellij: failed to trust project before opening: $project_dir"
  emit_result failed trust-failed "$maximum_position" "$queue_wait" 0
  exit 1
fi

if is_ready_in_intellij "$project_dir"; then
  release_launch_claim
  print "open-codex-project-in-intellij: already open in IntelliJ after trust: $project_dir"
  update_reaper_registry touch "$project_dir" || exit 1
  emit_result ready ready "$maximum_position" "$queue_wait" 0
  exit 0
fi

if open_new_intellij_window "$project_dir"; then
  launch_seconds=$(( EPOCHREALTIME - launch_started ))
  release_launch_claim
  print "open-codex-project-in-intellij: queued launch completed; max-position=${maximum_position}; queue-wait=${queue_wait}s; launch=${launch_seconds}s"
  print "open-codex-project-in-intellij: opened in a new IntelliJ window: $project_dir"
  if wait_for_serena_service "$project_dir"; then
    update_reaper_registry register "$project_dir" || exit 1
    emit_result ready ready "$maximum_position" "$queue_wait" "$launch_seconds"
    exit 0
  else
    ready_status=$?
    emit_result failed readiness-deadline "$maximum_position" "$queue_wait" "$launch_seconds"
    exit "$ready_status"
  fi
fi

release_launch_claim
print -u2 "open-codex-project-in-intellij: IntelliJ launcher or app bundle not found"
emit_result failed launch-failed "$maximum_position" "$queue_wait" 0
exit 1
