#!/usr/bin/env python3
"""Reuse one persistent Serena MCP service per worktree and backend.

Codex starts MCP commands over stdio for each task. This helper keeps the
project-scoped Serena server alive over loopback Streamable HTTP and runs a
small stdio proxy for each connected Codex task. Persistent processes are
identified conservatively and only broker-owned processes may be terminated.
"""

from __future__ import annotations

import argparse
from contextlib import contextmanager
from dataclasses import dataclass
from datetime import datetime, timezone
import fcntl
import hashlib
import json
import os
from pathlib import Path
import pwd
import re
import shlex
import shutil
import signal
import socket
import subprocess
import sys
import time
from typing import Any, Iterator, Sequence
import uuid


BIN_DIR = Path(__file__).resolve().parent
if str(BIN_DIR) not in sys.path:
    sys.path.insert(0, str(BIN_DIR))
from workspace_harbor_bridge import BridgeEvent, BridgeJournal, root_digest


CODEX_HOME = Path(os.environ.get("CODEX_HOME", Path.home() / ".codex"))
SESSION_DIR = Path(
    os.environ.get("WORKSPACE_HARBOR_SESSION_DIR", CODEX_HOME / "sessions")
)
STATE_DIR = Path(
    os.environ.get("SERENA_BROKER_STATE_DIR", CODEX_HOME / "state" / "serena-broker")
)
STATE_FILE = STATE_DIR / "services.json"
LOCK_FILE = STATE_DIR / "services.lock"
LOG_DIR = STATE_DIR / "logs"
BRIDGE_JOURNAL = BridgeJournal(
    Path(os.environ.get("SERENA_BRIDGE_STATE_DIR", CODEX_HOME / "state" / "serena-bridge"))
)
SERENA_CODEX = Path(
    os.environ.get("SERENA_BROKER_SERENA_CODEX", CODEX_HOME / "bin" / "serena-codex")
)
REAL_SERENA = Path(
    os.environ.get(
        "SERENA_BROKER_REAL_SERENA",
        Path.home() / ".local" / "share" / "uv" / "tools" / "serena-agent" / "bin" / "serena",
    )
)
MCP_PROXY = Path(
    os.environ.get("SERENA_BROKER_MCP_PROXY", Path.home() / ".local" / "bin" / "mcp-proxy")
)
HYBRID_GATEWAY = Path(
    os.environ.get(
        "SERENA_BROKER_HYBRID_GATEWAY", CODEX_HOME / "bin" / "serena-hybrid-mcp"
    )
)
INTELLIJ_LAUNCHER = Path(
    os.environ.get(
        "SERENA_BROKER_INTELLIJ_LAUNCHER",
        CODEX_HOME / "bin" / "open-codex-project-in-intellij",
    )
)
PROJECT_DOCTOR = Path(
    os.environ.get(
        "SERENA_BROKER_PROJECT_DOCTOR",
        CODEX_HOME / "bin" / "serena-project-doctor",
    )
)
BOOTSTRAP = Path(
    os.environ.get(
        "SERENA_BROKER_BOOTSTRAP",
        CODEX_HOME / "bin" / "workspace-harbor-bootstrap",
    )
)
PORT_FIRST = int(os.environ.get("SERENA_BROKER_PORT_FIRST", "24320"))
PORT_LAST = int(os.environ.get("SERENA_BROKER_PORT_LAST", "24419"))
DEFAULT_IDLE_SECONDS = int(os.environ.get("SERENA_BROKER_IDLE_SECONDS", "900"))
START_TIMEOUT_SECONDS = float(os.environ.get("SERENA_BROKER_START_TIMEOUT", "30"))
OPENER_BOOTSTRAP_TIMEOUT_SECONDS = float(
    os.environ.get("WORKSPACE_HARBOR_BOOTSTRAP_OPENER_TIMEOUT_SECONDS", "1860")
)
OPENER_READY_TIMEOUT_SECONDS = float(
    os.environ.get("INTELLIJ_SERENA_READY_TIMEOUT", "120")
)
OPENER_OPERATION_TIMEOUT_SECONDS = float(
    os.environ.get("INTELLIJ_OPENER_OPERATION_TIMEOUT", "300")
)
OPENER_QUEUE_TIMEOUT_SECONDS = float(
    os.environ.get("INTELLIJ_OPENER_QUEUE_TIMEOUT", "300")
)


def minimum_intellij_opener_timeout() -> float:
    return (
        OPENER_BOOTSTRAP_TIMEOUT_SECONDS
        + 10
        + OPENER_OPERATION_TIMEOUT_SECONDS
        + OPENER_QUEUE_TIMEOUT_SECONDS
        + OPENER_READY_TIMEOUT_SECONDS
        + 10
    )


INTELLIJ_LAUNCH_TIMEOUT_SECONDS = float(
    os.environ.get(
        "SERENA_BROKER_INTELLIJ_LAUNCH_TIMEOUT",
        str(minimum_intellij_opener_timeout()),
    )
)
OPENER_RESULT_PREFIX = "WORKSPACE_HARBOR_RESULT "
ALLOWED_OPENER_PHASES = {
    "operation-deadline",
    "queue-deadline",
    "readiness-deadline",
    "trust-failed",
    "launch-failed",
    "state-invalid",
}
THREAD_ID_PATTERN = re.compile(
    r"^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
)
LEGACY_PROCESS_OWNER_PATTERN = re.compile(r"^manual-pid-([1-9][0-9]*)$")
MAX_SESSION_META_BYTES = 65_536
MAX_LINEAGE_DEPTH = 8
HYBRID_FALSE_VALUES = frozenset({"0", "false", "no", "off"})


@dataclass(frozen=True)
class HybridCppActivation:
    enabled: bool
    clangd_path: str | None
    reason: str


def _opener_result(completed: subprocess.CompletedProcess[str]) -> dict[str, Any]:
    for line in reversed(completed.stdout.splitlines()):
        if not line.startswith(OPENER_RESULT_PREFIX):
            continue
        try:
            payload = json.loads(line.removeprefix(OPENER_RESULT_PREFIX))
        except json.JSONDecodeError:
            return {}
        if not isinstance(payload, dict) or payload.get("phase") not in ALLOWED_OPENER_PHASES:
            return {}
        maximum_position = payload.get("maximum_queue_position", 0)
        queue_wait = payload.get("queue_wait_seconds", 0)
        launch_seconds = payload.get("launch_seconds", 0)
        if (
            not isinstance(maximum_position, int)
            or isinstance(maximum_position, bool)
            or not 0 <= maximum_position <= 100_000
            or not isinstance(queue_wait, (int, float))
            or isinstance(queue_wait, bool)
            or not 0 <= float(queue_wait) <= 100_000
            or not isinstance(launch_seconds, (int, float))
            or isinstance(launch_seconds, bool)
            or not 0 <= float(launch_seconds) <= 100_000
        ):
            return {}
        return {
            "phase": payload["phase"],
            "maximum_queue_position": maximum_position,
            "queue_wait_seconds": queue_wait,
            "launch_seconds": launch_seconds,
        }
    return {}


@dataclass(frozen=True)
class OwnerResolution:
    thread_id: str | None
    owner_id: str
    source: str
    reason: str | None = None


@dataclass(frozen=True)
class CodexHostIdentity:
    pid: int
    process_started: str
    owner_id: str


def _now() -> str:
    return datetime.now(timezone.utc).isoformat()


def _parse_time(value: str | None) -> datetime | None:
    if not value:
        return None
    try:
        return datetime.fromisoformat(value)
    except ValueError:
        return None


def _ensure_state_dir() -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True, mode=0o700)
    LOG_DIR.mkdir(parents=True, exist_ok=True, mode=0o700)
    os.chmod(STATE_DIR, 0o700)
    os.chmod(LOG_DIR, 0o700)


@contextmanager
def _locked_state() -> Iterator[dict[str, Any]]:
    _ensure_state_dir()
    with LOCK_FILE.open("a+", encoding="utf-8") as lock_handle:
        os.chmod(LOCK_FILE, 0o600)
        fcntl.flock(lock_handle.fileno(), fcntl.LOCK_EX)
        state = _load_state()
        try:
            yield state
        finally:
            _write_state(state)
            fcntl.flock(lock_handle.fileno(), fcntl.LOCK_UN)


def _load_state() -> dict[str, Any]:
    if not STATE_FILE.is_file():
        return {"version": 1, "services": {}}
    try:
        loaded = json.loads(STATE_FILE.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        backup = STATE_FILE.with_name(f"services.corrupt-{int(time.time())}.json")
        try:
            STATE_FILE.replace(backup)
        except OSError:
            pass
        return {"version": 1, "services": {}}
    if not isinstance(loaded, dict) or not isinstance(loaded.get("services"), dict):
        return {"version": 1, "services": {}}
    loaded["version"] = 1
    return loaded


def _write_state(state: dict[str, Any]) -> None:
    temporary = STATE_FILE.with_suffix(f".{os.getpid()}.tmp")
    temporary.write_text(json.dumps(state, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    os.chmod(temporary, 0o600)
    temporary.replace(STATE_FILE)


def _service_key(
    project_root: Path, backend: str, context: str, added_modes: Sequence[str] = ()
) -> str:
    identity = json.dumps(
        [
            str(project_root.resolve()),
            backend.lower(),
            str(Path(context).expanduser()),
            list(added_modes),
        ],
        separators=(",", ":"),
    )
    return hashlib.sha256(identity.encode("utf-8")).hexdigest()[:20]


def _process_details(pid: int) -> tuple[str, str] | None:
    result = subprocess.run(
        ["ps", "-p", str(pid), "-o", "lstart=", "-o", "command="],
        check=False,
        capture_output=True,
        text=True,
    )
    if result.returncode != 0 or not result.stdout.strip():
        return None
    line = result.stdout.strip()
    # macOS lstart is five whitespace-separated fields.
    parts = line.split(maxsplit=5)
    if len(parts) < 6:
        return None
    return " ".join(parts[:5]), parts[5]


def _parent_pid(pid: int) -> int | None:
    result = subprocess.run(
        ["ps", "-p", str(pid), "-o", "ppid="],
        check=False,
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        return None
    try:
        return int(result.stdout.strip())
    except ValueError:
        return None


def _command_tokens(command: str) -> list[str]:
    try:
        return shlex.split(command)
    except ValueError:
        return []


def _trusted_codex_executables() -> set[Path]:
    candidates = {
        Path("/Applications/ChatGPT.app/Contents/Resources/codex").resolve()
    }
    command = shutil.which("codex")
    if command:
        candidates.add(Path(command).resolve())
    return candidates


def _codex_host_identity(child_pid: int) -> CodexHostIdentity | None:
    parent_pid = _parent_pid(child_pid)
    if parent_pid is None:
        return None
    details = _process_details(parent_pid)
    if details is None:
        return None
    process_started, command = details
    tokens = _command_tokens(command)
    if not tokens:
        return None
    executable = Path(tokens[0]).expanduser().resolve()
    if executable not in _trusted_codex_executables():
        return None
    if not ({"app-server", "exec"} & set(tokens[1:])):
        return None
    digest = hashlib.sha256(
        f"{parent_pid}\0{process_started}\0{executable}".encode("utf-8")
    ).hexdigest()[:24]
    return CodexHostIdentity(parent_pid, process_started, f"codex-host-{digest}")


def _process_is_owned(record: dict[str, Any]) -> bool:
    try:
        pid = int(record["pid"])
        port = int(record["port"])
        root = str(Path(record["project_root"]).resolve())
        expected_start = str(record["process_started"])
    except (KeyError, TypeError, ValueError, OSError):
        return False
    details = _process_details(pid)
    if details is None:
        return False
    actual_start, command = details
    return (
        actual_start == expected_start
        and "serena" in command
        and "start-mcp-server" in command
        and f"--port={port}" in command
        and root in command
        and "--transport=streamable-http" in command
    )


def _tcp_ready(port: int, timeout: float = 0.25) -> bool:
    try:
        with socket.create_connection(("127.0.0.1", port), timeout=timeout):
            return True
    except OSError:
        return False


def _free_port(used_ports: set[int]) -> int:
    for port in range(PORT_FIRST, PORT_LAST + 1):
        if port in used_ports:
            continue
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as probe:
            try:
                probe.bind(("127.0.0.1", port))
            except OSError:
                continue
        return port
    raise RuntimeError(f"no free Serena broker port in {PORT_FIRST}-{PORT_LAST}")


def _prune_dead_leases(record: dict[str, Any]) -> None:
    leases = record.get("leases")
    if not isinstance(leases, dict):
        record["leases"] = {}
        return
    for lease_id, lease in list(leases.items()):
        if not isinstance(lease, dict):
            leases.pop(lease_id, None)
            continue
        details = _process_details(int(lease.get("pid", -1)))
        if details is None or details[0] != lease.get("process_started"):
            leases.pop(lease_id, None)
    if not leases and record.get("idle_since") is None:
        record["idle_since"] = _now()


def _validate_owner_value(value: str) -> None:
    if len(value) > 128 or any(character.isspace() for character in value):
        raise RuntimeError("invalid Workspace Harbor owner identity")


def _session_meta(thread_id: str) -> tuple[dict[str, Any] | None, str | None]:
    matches = [
        path
        for path in SESSION_DIR.glob(f"*/*/*/*-{thread_id}.jsonl")
        if path.is_file()
    ]
    if not matches:
        return None, "missing-session"
    if len(matches) != 1:
        return None, "ambiguous-session"
    try:
        with matches[0].open("rb") as handle:
            line = handle.readline(MAX_SESSION_META_BYTES + 1)
        if len(line) > MAX_SESSION_META_BYTES or not line.endswith(b"\n"):
            return None, "oversized-session-meta"
        record = json.loads(line.decode("utf-8"))
    except (OSError, UnicodeDecodeError, json.JSONDecodeError):
        return None, "invalid-session-meta"
    if not isinstance(record, dict) or record.get("type") != "session_meta":
        return None, "invalid-session-meta"
    payload = record.get("payload")
    if not isinstance(payload, dict) or payload.get("id") != thread_id:
        return None, "invalid-session-meta"
    return payload, None


def _lineage_owner(thread_id: str) -> OwnerResolution:
    current = thread_id
    visited: set[str] = set()
    transitions = 0
    while True:
        if current in visited:
            return OwnerResolution(thread_id, thread_id, "root-thread", "lineage-cycle")
        visited.add(current)
        payload, reason = _session_meta(current)
        if payload is None:
            return OwnerResolution(thread_id, thread_id, "root-thread", reason)

        parent = payload.get("parent_thread_id")
        thread_source = payload.get("thread_source")
        if parent is None:
            if thread_source == "subagent":
                return OwnerResolution(thread_id, thread_id, "root-thread", "missing-parent")
            source = "subagent-lineage" if transitions else "root-thread"
            return OwnerResolution(thread_id, current, source)
        if thread_source != "subagent":
            return OwnerResolution(
                thread_id, thread_id, "root-thread", "invalid-thread-source"
            )
        source = payload.get("source")
        subagent = source.get("subagent") if isinstance(source, dict) else None
        spawn = subagent.get("thread_spawn") if isinstance(subagent, dict) else None
        nested_parent = spawn.get("parent_thread_id") if isinstance(spawn, dict) else None
        if not isinstance(parent, str) or nested_parent != parent:
            return OwnerResolution(
                thread_id, thread_id, "root-thread", "inconsistent-parent"
            )
        if not THREAD_ID_PATTERN.fullmatch(parent):
            return OwnerResolution(
                thread_id, thread_id, "root-thread", "invalid-parent-id"
            )
        if transitions >= MAX_LINEAGE_DEPTH:
            return OwnerResolution(
                thread_id, thread_id, "root-thread", "lineage-too-deep"
            )
        transitions += 1
        current = parent


def _owner_resolution() -> OwnerResolution:
    """Resolve a Codex subagent to its root logical task without weakening isolation."""
    explicit = os.environ.get("WORKSPACE_HARBOR_OWNER_ID", "").strip()
    thread = os.environ.get("CODEX_THREAD_ID", "").strip()
    if explicit:
        _validate_owner_value(explicit)
        return OwnerResolution(thread or None, explicit, "explicit")
    if thread:
        _validate_owner_value(thread)
        if not THREAD_ID_PATTERN.fullmatch(thread):
            return OwnerResolution(thread, thread, "root-thread", "invalid-thread-id")
        return _lineage_owner(thread)
    host = _codex_host_identity(os.getpid())
    if host is not None:
        return OwnerResolution(None, host.owner_id, "codex-host")
    return OwnerResolution(None, f"manual-pid-{os.getpid()}", "process-fallback")


def _owner_id() -> str:
    """Return the logical Codex task group that owns a worktree lease."""
    return _owner_resolution().owner_id


def _root_owners(state: dict[str, Any], project_root: Path) -> set[str]:
    """Return live logical owners for one canonical worktree root."""
    canonical_root = str(project_root.resolve())
    owners: set[str] = set()
    for record in state.get("services", {}).values():
        if not isinstance(record, dict):
            continue
        try:
            record_root = str(Path(record.get("project_root", "")).resolve())
        except (OSError, TypeError, ValueError):
            continue
        if record_root != canonical_root:
            continue
        _prune_dead_leases(record)
        for lease in record.get("leases", {}).values():
            if not isinstance(lease, dict):
                continue
            owner = lease.get("owner_id")
            if isinstance(owner, str) and owner:
                owners.add(owner)
            else:
                owners.add(f"legacy-pid-{lease.get('pid', 'unknown')}")
    return owners


def _assert_root_owner(state: dict[str, Any], project_root: Path, owner_id: str) -> None:
    owners = _root_owners(state, project_root)
    if owners and owners != {owner_id}:
        raise RuntimeError(
            f"worktree is owned by another Codex task: {sorted(owners)}"
        )


def _is_deployed_broker_command(command: str) -> bool:
    """Return whether a process command is this broker's connect entry point."""
    tokens = _command_tokens(command)
    if not tokens:
        return False
    broker_path = Path(__file__).resolve()
    broker_index: int | None = None
    for index, token in enumerate(tokens[:3]):
        if token.startswith("-"):
            continue
        try:
            if Path(token).expanduser().resolve() == broker_path:
                broker_index = index
                break
        except (OSError, RuntimeError, ValueError):
            continue
    if broker_index is None:
        return False
    if broker_index == 1 and not Path(tokens[0]).name.startswith("python"):
        return False
    if broker_index == 2 and not (
        Path(tokens[0]).name == "env" and Path(tokens[1]).name.startswith("python")
    ):
        return False
    return "connect" in tokens[broker_index + 1 :]


def _migrate_legacy_host_leases(
    state: dict[str, Any],
    project_root: Path,
    resolution: OwnerResolution,
) -> bool:
    """Adopt live process-scoped leases proven to belong to this Codex host."""
    if resolution.source != "codex-host":
        return False
    services = state.get("services")
    if not isinstance(services, dict):
        return False
    try:
        canonical_root = str(project_root.resolve())
    except (OSError, RuntimeError, TypeError, ValueError):
        return False

    candidates: list[dict[str, Any]] = []
    for record in services.values():
        if not isinstance(record, dict):
            return False
        raw_root = record.get("project_root")
        if not isinstance(raw_root, str) or not raw_root:
            return False
        try:
            record_root = str(Path(raw_root).resolve())
        except (OSError, RuntimeError, TypeError, ValueError):
            return False
        if record_root != canonical_root:
            continue

        _prune_dead_leases(record)
        leases = record.get("leases")
        if not isinstance(leases, dict):
            return False
        for lease in leases.values():
            if not isinstance(lease, dict):
                return False
            owner_id = lease.get("owner_id")
            if owner_id == resolution.owner_id:
                continue
            if not isinstance(owner_id, str):
                return False
            match = LEGACY_PROCESS_OWNER_PATTERN.fullmatch(owner_id)
            if match is None:
                return False
            pid = lease.get("pid")
            if isinstance(pid, bool) or not isinstance(pid, int):
                return False
            if int(match.group(1)) != pid:
                return False
            process_started = lease.get("process_started")
            if not isinstance(process_started, str) or not process_started:
                return False
            details = _process_details(pid)
            if details is None or details[0] != process_started:
                return False
            if not _is_deployed_broker_command(details[1]):
                return False
            host = _codex_host_identity(pid)
            if host is None or host.owner_id != resolution.owner_id:
                return False
            candidates.append(lease)

    if not candidates:
        return False
    for lease in candidates:
        lease["owner_id"] = resolution.owner_id
    return True


def _stop_owned_service(record: dict[str, Any]) -> bool:
    if not _process_is_owned(record):
        return False
    pid = int(record["pid"])
    try:
        os.killpg(pid, signal.SIGTERM)
    except ProcessLookupError:
        return True
    deadline = time.monotonic() + 5
    while time.monotonic() < deadline:
        if _process_details(pid) is None:
            return True
        time.sleep(0.1)
    if _process_is_owned(record):
        try:
            os.killpg(pid, signal.SIGKILL)
        except ProcessLookupError:
            pass
    return True


def _stop_spawned_service(process: subprocess.Popen[Any]) -> None:
    """Stop a child that this broker spawned before it had a trusted record."""
    if process.poll() is not None:
        return
    try:
        os.killpg(process.pid, signal.SIGTERM)
    except ProcessLookupError:
        return
    try:
        process.wait(timeout=5)
        return
    except subprocess.TimeoutExpired:
        pass
    if process.poll() is None:
        try:
            os.killpg(process.pid, signal.SIGKILL)
        except ProcessLookupError:
            return
        try:
            process.wait(timeout=5)
        except subprocess.TimeoutExpired:
            pass


def _open_intellij(project_root: Path) -> None:
    if not INTELLIJ_LAUNCHER.is_file():
        raise RuntimeError(f"IntelliJ launcher not found: {INTELLIJ_LAUNCHER}")
    result = subprocess.run(
        [str(INTELLIJ_LAUNCHER), str(project_root)],
        check=False,
        capture_output=True,
        text=True,
        timeout=max(
            INTELLIJ_LAUNCH_TIMEOUT_SECONDS,
            minimum_intellij_opener_timeout(),
        ),
    )
    if result.returncode != 0:
        opener_result = _opener_result(result)
        if opener_result:
            metrics = ", ".join(
                f"{key}={opener_result[key]}"
                for key in (
                    "maximum_queue_position",
                    "queue_wait_seconds",
                    "launch_seconds",
                )
            )
            raise RuntimeError(
                f"failed to open IntelliJ project: {opener_result['phase']} ({metrics})"
            )
        message = result.stderr.strip() or result.stdout.strip()
        raise RuntimeError(f"failed to open IntelliJ project: {message}")


def _auto_repair_project_languages(project_root: Path) -> dict[str, Any]:
    if not PROJECT_DOCTOR.is_file():
        raise RuntimeError(f"Serena project doctor not found: {PROJECT_DOCTOR}")
    result = subprocess.run(
        [str(PROJECT_DOCTOR), "--repair-languages", "--json", str(project_root)],
        check=False,
        capture_output=True,
        text=True,
        timeout=90,
    )
    if result.returncode != 0:
        message = result.stderr.strip() or result.stdout.strip()
        raise RuntimeError(f"Serena language auto-repair failed: {message}")
    try:
        payload = json.loads(result.stdout)
    except json.JSONDecodeError as error:
        raise RuntimeError("Serena language auto-repair returned malformed JSON") from error
    return payload if isinstance(payload, dict) else {}


def _hybrid_cpp_activation(
    project_root: Path, doctor_payload: object
) -> HybridCppActivation:
    enabled_value = os.environ.get("SERENA_HYBRID_CPP_ENABLED", "1")
    if enabled_value.strip().casefold() in HYBRID_FALSE_VALUES:
        return HybridCppActivation(False, None, "disabled")
    if not isinstance(doctor_payload, dict):
        return HybridCppActivation(False, None, "invalid-doctor-payload")

    language_sources: list[object] = [
        doctor_payload.get("configured_languages"),
        doctor_payload.get("detected_languages"),
    ]
    language_repair = doctor_payload.get("language_repair")
    if language_repair is not None:
        if not isinstance(language_repair, dict):
            return HybridCppActivation(False, None, "invalid-doctor-payload")
        language_sources.extend(
            (
                language_repair.get("configured_languages"),
                language_repair.get("detected_languages"),
            )
        )

    languages: set[str] = set()
    for source in language_sources:
        if source is None:
            continue
        if not isinstance(source, list) or not all(
            isinstance(language, str) for language in source
        ):
            return HybridCppActivation(False, None, "invalid-doctor-payload")
        languages.update(language.casefold() for language in source)
    if "cpp" not in languages:
        return HybridCppActivation(False, None, "language-missing")

    clangd_path = shutil.which("clangd")
    if not clangd_path:
        return HybridCppActivation(False, None, "clangd-unavailable")
    return HybridCppActivation(True, clangd_path, "enabled")


def _hybrid_gateway_status(gateway: Path) -> str:
    if not gateway.is_file() or not os.access(gateway, os.X_OK):
        return "missing"
    try:
        result = subprocess.run(
            [str(gateway), "--runtime-check"],
            check=False,
            capture_output=True,
            timeout=5,
        )
    except (OSError, subprocess.SubprocessError):
        return "unavailable"
    return "ready" if result.returncode == 0 else "unavailable"


def _bootstrap_status(project_root: Path) -> dict[str, Any]:
    if not BOOTSTRAP.is_file() or not os.access(BOOTSTRAP, os.X_OK):
        raise RuntimeError(f"Workspace Harbor bootstrap not found: {BOOTSTRAP}")
    try:
        result = subprocess.run(
            [str(BOOTSTRAP), "status", str(project_root), "--json"],
            check=False,
            capture_output=True,
            text=True,
            timeout=5,
        )
    except (OSError, subprocess.SubprocessError) as error:
        raise RuntimeError(f"Workspace Harbor bootstrap status failed: {error}") from error
    try:
        payload = json.loads(result.stdout)
    except json.JSONDecodeError as error:
        raise RuntimeError("Workspace Harbor bootstrap returned malformed status") from error
    allowed_codes = {
        "ready": 0,
        "pending": 0,
        "not-needed": 0,
        "disabled": 0,
        "failed": 1,
        "needs-decision": 3,
    }
    status = payload.get("status") if isinstance(payload, dict) else None
    if not isinstance(status, str) or allowed_codes.get(status) != result.returncode:
        message = result.stderr.strip() or "invalid status contract"
        raise RuntimeError(f"Workspace Harbor bootstrap status is invalid: {message}")
    return payload


def _start_service(
    state: dict[str, Any],
    project_root: Path,
    backend: str,
    context: str,
    added_modes: Sequence[str] = (),
) -> tuple[str, dict[str, Any]]:
    services = state["services"]
    key = _service_key(project_root, backend, context, added_modes)
    existing = services.get(key)
    if isinstance(existing, dict):
        _prune_dead_leases(existing)
        if _process_is_owned(existing) and _tcp_ready(int(existing["port"])):
            existing["last_used_at"] = _now()
            existing["idle_since"] = None
            return key, existing
        if _process_is_owned(existing):
            _stop_owned_service(existing)
        services.pop(key, None)

    if backend.lower() == "jetbrains":
        _open_intellij(project_root)

    used_ports = {
        int(item["port"])
        for item in services.values()
        if isinstance(item, dict) and str(item.get("port", "")).isdigit()
    }
    port = _free_port(used_ports)
    log_path = LOG_DIR / f"{key}.log"
    command = [
        str(SERENA_CODEX),
        "start-mcp-server",
        f"--context={context}",
        f"--project={project_root}",
        f"--language-backend={backend}",
        "--transport=streamable-http",
        "--host=127.0.0.1",
        f"--port={port}",
        "--enable-web-dashboard=false",
        "--enable-gui-log-window=false",
        "--open-web-dashboard=false",
    ]
    command.extend(f"--add-mode={mode}" for mode in added_modes)
    environment = os.environ.copy()
    environment["SERENA_BROKER_SERVICE_KEY"] = key
    with log_path.open("ab", buffering=0) as log_handle:
        process = subprocess.Popen(
            command,
            cwd=project_root,
            env=environment,
            stdin=subprocess.DEVNULL,
            stdout=log_handle,
            stderr=subprocess.STDOUT,
            start_new_session=True,
        )
    details = None
    for _ in range(20):
        details = _process_details(process.pid)
        if details is not None and "start-mcp-server" in details[1]:
            break
        if process.poll() is not None:
            break
        time.sleep(0.05)
    if details is None:
        _stop_spawned_service(process)
        raise RuntimeError(f"Serena service exited during startup; see {log_path}")
    if "start-mcp-server" not in details[1]:
        _stop_spawned_service(process)
        raise RuntimeError(
            f"Serena service identity could not be verified during startup; see {log_path}"
        )
    record: dict[str, Any] = {
        "backend": backend,
        "context": context,
        "added_modes": list(added_modes),
        "created_at": _now(),
        "idle_since": None,
        "last_used_at": _now(),
        "leases": {},
        "log_path": str(log_path),
        "pid": process.pid,
        "port": port,
        "process_started": details[0],
        "project_root": str(project_root),
    }
    services[key] = record
    deadline = time.monotonic() + START_TIMEOUT_SECONDS
    while time.monotonic() < deadline:
        if process.poll() is not None:
            services.pop(key, None)
            raise RuntimeError(f"Serena service failed to start; see {log_path}")
        if _tcp_ready(port):
            return key, record
        time.sleep(0.2)
    _stop_owned_service(record)
    services.pop(key, None)
    raise RuntimeError(f"Serena service did not listen within {START_TIMEOUT_SECONDS:g}s; see {log_path}")


def _resolve_project(explicit_project: str | None) -> Path | None:
    if explicit_project:
        project = Path(explicit_project).expanduser().resolve()
        if not project.is_dir():
            raise RuntimeError(f"project is not a directory: {project}")
        return project
    result = subprocess.run(
        [str(SERENA_CODEX), "resolve-project", str(Path.cwd())],
        check=False,
        capture_output=True,
        text=True,
    )
    if result.returncode == 0:
        return Path(result.stdout.strip()).resolve()
    if result.returncode == 1:
        return None
    raise RuntimeError(result.stderr.strip() or "could not resolve Serena project")


def _project_is_brokerable(project_root: Path) -> bool:
    """Return whether the root is eligible for managed IntelliJ lifecycle."""
    account_home = Path(pwd.getpwuid(os.getuid()).pw_dir)
    allowed_parents = (
        account_home / "Developer/Codex",
        account_home / ".codex/src",
    )
    try:
        canonical = project_root.resolve(strict=True)
    except OSError:
        return False
    for parent in allowed_parents:
        try:
            canonical.relative_to(parent.resolve(strict=True))
        except (OSError, ValueError):
            continue
        return True
    return False


def _direct_stdio_fallback(
    backend: str,
    context: str,
    added_modes: Sequence[str] = (),
    *,
    project_from_cwd: bool = True,
) -> int:
    command = [
        str(SERENA_CODEX),
        "start-mcp-server",
        f"--context={context}",
        f"--language-backend={backend}",
        "--enable-web-dashboard=false",
        "--enable-gui-log-window=false",
        "--open-web-dashboard=false",
    ]
    if project_from_cwd:
        command.insert(3, "--project-from-cwd")
    command.extend(f"--add-mode={mode}" for mode in added_modes)
    os.execv(str(SERENA_CODEX), command)
    return 127


def _bridge_event(
    attempt_id: str,
    started: float,
    stage: str,
    outcome: str,
    *,
    root: Path | None = None,
    service_key: str | None = None,
    owner_source: str | None = None,
    reason: str | None = None,
) -> None:
    BRIDGE_JOURNAL.append(
        BridgeEvent(
            attempt_id=attempt_id,
            timestamp=datetime.now(timezone.utc).isoformat(),
            root_digest=root_digest(root) if root is not None else None,
            service_key=service_key,
            owner_source=owner_source,
            stage=stage,
            outcome=outcome,
            reason=reason,
            duration_ms=max(0, round((time.monotonic() - started) * 1000)),
        )
    )


def _connect(args: argparse.Namespace) -> int:
    attempt_id = uuid.uuid4().hex
    started = time.monotonic()
    try:
        project_root = _resolve_project(args.project)
    except (OSError, RuntimeError, subprocess.SubprocessError):
        _bridge_event(
            attempt_id,
            started,
            "project-resolution",
            "failed",
            reason="project-resolution-failed",
        )
        raise
    _bridge_event(attempt_id, started, "project-resolution", "ok", root=project_root)
    if project_root is None:
        _bridge_event(
            attempt_id,
            started,
            "projectless-fallback",
            "ok",
            reason="project-not-found",
        )
        return _direct_stdio_fallback(
            args.backend,
            args.context,
            args.add_mode,
            project_from_cwd=False,
        )
    if args.project is None and not _project_is_brokerable(project_root):
        _bridge_event(
            attempt_id,
            started,
            "projectless-fallback",
            "ok",
            root=project_root,
            reason="project-outside-managed-roots",
        )
        return _direct_stdio_fallback(
            args.backend,
            args.context,
            args.add_mode,
            project_from_cwd=False,
        )
    doctor_payload = _auto_repair_project_languages(project_root)
    _bootstrap_status(project_root)
    activation = _hybrid_cpp_activation(project_root, doctor_payload)
    hybrid_requested = activation.enabled and args.backend.casefold() == "jetbrains"
    gateway_status = (
        _hybrid_gateway_status(HYBRID_GATEWAY) if hybrid_requested else "not-requested"
    )
    hybrid_enabled = hybrid_requested and gateway_status == "ready"
    if hybrid_requested and not hybrid_enabled:
        gateway_reason = (
            "hybrid-gateway-missing"
            if gateway_status == "missing"
            else "hybrid-gateway-unavailable"
        )
        _bridge_event(
            attempt_id,
            started,
            "secondary-service-unavailable",
            "unavailable",
            root=project_root,
            reason=gateway_reason,
        )
    if not hybrid_enabled and not MCP_PROXY.is_file():
        _bridge_event(
            attempt_id,
            started,
            "proxy-started",
            "failed",
            root=project_root,
            reason="proxy-missing",
        )
        raise RuntimeError(f"mcp-proxy not found: {MCP_PROXY}")

    lease_id = uuid.uuid4().hex
    key: str | None = None
    secondary_key: str | None = None
    leased_keys: list[str] = []
    secondary_port: int | None = None
    resolution: OwnerResolution | None = None
    try:
        resolution = _owner_resolution()
        owner_id = resolution.owner_id
        broker_details = _process_details(os.getpid())
        if broker_details is None:
            raise RuntimeError("could not identify broker process")
        with _locked_state() as state:
            _cleanup_state(state, DEFAULT_IDLE_SECONDS, stop_idle=False)
            _migrate_legacy_host_leases(state, project_root, resolution)
            _assert_root_owner(state, project_root, owner_id)
            _bridge_event(
                attempt_id,
                started,
                "ownership",
                "ok",
                root=project_root,
                owner_source=resolution.source,
            )
            expected_key = _service_key(
                project_root, args.backend, args.context, args.add_mode
            )
            previous = state["services"].get(expected_key)
            key, record = _start_service(
                state, project_root, args.backend, args.context, args.add_mode
            )
            service_stage = "service-reused" if previous is record else "service-started"
            _bridge_event(
                attempt_id,
                started,
                service_stage,
                "ok",
                root=project_root,
                service_key=key,
                owner_source=resolution.source,
            )
            record["leases"][lease_id] = {
                "created_at": _now(),
                "owner_id": owner_id,
                "pid": os.getpid(),
                "process_started": broker_details[0],
            }
            record["idle_since"] = None
            leased_keys.append(key)
            port = int(record["port"])
            _bridge_event(
                attempt_id,
                started,
                "lease-inserted",
                "ok",
                root=project_root,
                service_key=key,
                owner_source=resolution.source,
            )
            if hybrid_enabled:
                expected_secondary_key = _service_key(
                    project_root, "LSP", args.context, args.add_mode
                )
                previous_secondary = state["services"].get(expected_secondary_key)
                try:
                    secondary_key, secondary_record = _start_service(
                        state, project_root, "LSP", args.context, args.add_mode
                    )
                except (OSError, RuntimeError, subprocess.SubprocessError):
                    _bridge_event(
                        attempt_id,
                        started,
                        "secondary-service-unavailable",
                        "unavailable",
                        root=project_root,
                        service_key=expected_secondary_key,
                        owner_source=resolution.source,
                        reason="clangd-unavailable",
                    )
                else:
                    secondary_stage = (
                        "secondary-service-reused"
                        if previous_secondary is secondary_record
                        else "secondary-service-started"
                    )
                    _bridge_event(
                        attempt_id,
                        started,
                        secondary_stage,
                        "ok",
                        root=project_root,
                        service_key=secondary_key,
                        owner_source=resolution.source,
                    )
                    secondary_record["leases"][lease_id] = {
                        "created_at": _now(),
                        "owner_id": owner_id,
                        "pid": os.getpid(),
                        "process_started": broker_details[0],
                    }
                    secondary_record["idle_since"] = None
                    leased_keys.append(secondary_key)
                    secondary_port = int(secondary_record["port"])
    except (OSError, RuntimeError, subprocess.SubprocessError):
        _bridge_event(
            attempt_id,
            started,
            "ownership",
            "failed",
            root=project_root,
            service_key=key,
            owner_source=resolution.source if resolution is not None else None,
            reason="ownership-or-service-failed",
        )
        raise

    if hybrid_enabled:
        proxy_command = [
            str(HYBRID_GATEWAY),
            "--project-root",
            str(project_root),
            "--primary-url",
            f"http://127.0.0.1:{port}/mcp",
        ]
        if secondary_port is None:
            proxy_command.extend(("--secondary-error", "clangd-unavailable"))
        else:
            proxy_command.extend(
                ("--secondary-url", f"http://127.0.0.1:{secondary_port}/mcp")
            )
        proxy_stage = "hybrid-proxy-started"
    else:
        proxy_command = [
            str(MCP_PROXY),
            f"http://127.0.0.1:{port}/mcp",
            "--transport=streamablehttp",
            "--log-level=WARNING",
        ]
        proxy_stage = "proxy-started"
    _bridge_event(
        attempt_id,
        started,
        proxy_stage,
        "ok",
        root=project_root,
        service_key=key,
        owner_source=resolution.source,
    )
    try:
        returncode = subprocess.run(proxy_command, check=False).returncode
        _bridge_event(
            attempt_id,
            started,
            "proxy-exit",
            "ok" if returncode == 0 else "failed",
            root=project_root,
            service_key=key,
            owner_source=resolution.source,
            reason=None if returncode == 0 else f"proxy-exit-{returncode}",
        )
        return returncode
    finally:
        try:
            with _locked_state() as state:
                for leased_key in leased_keys:
                    current = state["services"].get(leased_key)
                    if isinstance(current, dict):
                        leases = current.setdefault("leases", {})
                        leases.pop(lease_id, None)
                        _prune_dead_leases(current)
                        current["last_used_at"] = _now()
            _bridge_event(
                attempt_id,
                started,
                "lease-cleanup",
                "ok",
                root=project_root,
                service_key=key,
                owner_source=resolution.source,
            )
        except (OSError, RuntimeError, subprocess.SubprocessError):
            _bridge_event(
                attempt_id,
                started,
                "lease-cleanup",
                "failed",
                root=project_root,
                service_key=key,
                owner_source=resolution.source,
                reason="lease-cleanup-failed",
            )
            raise


def _cleanup_state(state: dict[str, Any], idle_seconds: int, stop_idle: bool = True) -> list[str]:
    actions: list[str] = []
    now = datetime.now(timezone.utc)
    for key, record in list(state["services"].items()):
        if not isinstance(record, dict):
            state["services"].pop(key, None)
            actions.append(f"removed invalid state {key}")
            continue
        _prune_dead_leases(record)
        if not _process_is_owned(record):
            state["services"].pop(key, None)
            actions.append(f"removed stale state {key}")
            continue
        if record.get("leases") or not stop_idle:
            continue
        idle_since = _parse_time(record.get("idle_since"))
        if idle_since is None or (now - idle_since).total_seconds() < idle_seconds:
            continue
        if _stop_owned_service(record):
            state["services"].pop(key, None)
            actions.append(f"stopped idle service {key}")
    return actions


def _repair_root_state(state: dict[str, Any], project_root: Path) -> dict[str, str]:
    canonical_root = str(project_root.resolve())
    services = state.get("services")
    if not isinstance(services, dict):
        return {"status": "protected", "reason": "invalid-state"}
    matches = [
        (key, record)
        for key, record in services.items()
        if isinstance(record, dict)
        and isinstance(record.get("project_root"), str)
        and str(Path(record["project_root"]).expanduser().resolve(strict=False))
        == canonical_root
    ]
    if not matches:
        return {"status": "unchanged", "reason": "no-record"}
    if len(matches) > 1:
        backends = {
            str(record.get("backend", "")).casefold() for _, record in matches
        }
        if len(matches) != 2 or backends != {"jetbrains", "lsp"}:
            return {"status": "protected", "reason": "ambiguous-services"}

    for _, record in matches:
        _prune_dead_leases(record)
        if record.get("leases"):
            return {"status": "protected", "reason": "live-lease"}

    health = [
        _process_is_owned(record) and _tcp_ready(int(record.get("port", 0)))
        for _, record in matches
    ]
    if all(health):
        reason = "healthy-services" if len(matches) > 1 else "healthy-service"
        return {"status": "unchanged", "reason": reason}

    repair_reasons: list[str] = []
    for (key, record), healthy in zip(matches, health):
        if healthy:
            continue
        if _process_is_owned(record):
            if not _stop_owned_service(record):
                return {"status": "protected", "reason": "stop-failed"}
            repair_reasons.append("stopped-unhealthy-service")
        else:
            repair_reasons.append("removed-stale-record")
        services.pop(key, None)
    reason = repair_reasons[0] if len(matches) == 1 else "repaired-services"
    return {"status": "repaired", "reason": reason}


def _repair_root(args: argparse.Namespace) -> int:
    root = Path(args.root).expanduser().resolve()
    if not root.is_dir():
        raise RuntimeError(f"project is not a directory: {root}")
    with _locked_state() as state:
        result = _repair_root_state(state, root)
    payload = {"root": str(root), **result}
    if args.json:
        print(json.dumps(payload, sort_keys=True))
    else:
        print(f"{result['status']} {result['reason']} root={root}")
    return 0 if result["status"] != "protected" else 2


def _cleanup(args: argparse.Namespace) -> int:
    with _locked_state() as state:
        actions = _cleanup_state(state, args.idle_seconds)
    for action in actions:
        print(action)
    return 0


def _native_semantic_confidence(record: dict[str, Any]) -> str | None:
    if str(record.get("backend", "")).casefold() != "lsp":
        return None
    raw_root = record.get("project_root")
    if not isinstance(raw_root, str):
        return "fallback-flags"
    try:
        has_compile_database = (Path(raw_root) / "compile_commands.json").is_file()
    except OSError:
        has_compile_database = False
    return "compile-database" if has_compile_database else "fallback-flags"


def _status(args: argparse.Namespace) -> int:
    with _locked_state() as state:
        _cleanup_state(state, DEFAULT_IDLE_SECONDS, stop_idle=False)
        services = list(state["services"].items())
        payload = [
            {
                "key": key,
                "project_root": record.get("project_root"),
                "backend": record.get("backend"),
                "native_semantic_confidence": _native_semantic_confidence(record),
                "pid": record.get("pid"),
                "port": record.get("port"),
                "leases": len(record.get("leases", {})),
                "owners": sorted(
                    {
                        lease.get("owner_id", f"legacy-pid-{lease.get('pid', 'unknown')}")
                        for lease in record.get("leases", {}).values()
                        if isinstance(lease, dict)
                    }
                ),
                "idle_since": record.get("idle_since"),
                "healthy": _process_is_owned(record) and _tcp_ready(int(record.get("port", 0))),
            }
            for key, record in services
            if isinstance(record, dict)
        ]
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    elif not payload:
        print("No broker-owned Serena services.")
    else:
        for item in payload:
            confidence = item["native_semantic_confidence"]
            confidence_text = (
                f" native-confidence={confidence}" if confidence is not None else ""
            )
            print(
                f"{item['key']} {item['backend']} pid={item['pid']} port={item['port']} "
                f"leases={item['leases']} owners={','.join(item['owners']) or '-'} "
                f"healthy={str(item['healthy']).lower()}{confidence_text} "
                f"root={item['project_root']}"
            )
    return 0


def _leases(args: argparse.Namespace) -> int:
    """Emit the minimal, read-only lease boundary for the project reaper."""
    payload: dict[str, dict[str, Any]] = {}
    with _locked_state() as state:
        for record in state["services"].values():
            if not isinstance(record, dict) or not isinstance(record.get("project_root"), str):
                continue
            _prune_dead_leases(record)
            root = str(Path(record["project_root"]).expanduser().resolve(strict=False))
            item = payload.get(root)
            if item is None:
                payload[root] = {
                    "project_root": root,
                    "backend": record.get("backend"),
                    "live_leases": len(record.get("leases", {})),
                    "idle_since": record.get("idle_since"),
                    "last_used_at": record.get("last_used_at"),
                }
                continue
            item["live_leases"] += len(record.get("leases", {}))
            if record.get("last_used_at") and (not item["last_used_at"] or record["last_used_at"] > item["last_used_at"]):
                item["last_used_at"] = record["last_used_at"]
            if item["live_leases"]:
                item["idle_since"] = None
    print(json.dumps(payload, sort_keys=True))
    return 0


def _owner(args: argparse.Namespace) -> int:
    """Report only the resolved logical owner identity."""
    resolution = _owner_resolution()
    payload: dict[str, Any] = {
        "thread_id": resolution.thread_id,
        "owner_id": resolution.owner_id,
        "source": resolution.source,
    }
    if resolution.reason is not None:
        payload["reason"] = resolution.reason
    if args.json:
        print(json.dumps(payload, sort_keys=True))
    else:
        fields = [
            f"thread={resolution.thread_id or '-'}",
            f"owner={resolution.owner_id}",
            f"source={resolution.source}",
        ]
        if resolution.reason is not None:
            fields.append(f"reason={resolution.reason}")
        print(" ".join(fields))
    return 0


def _parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description=__doc__)
    subparsers = parser.add_subparsers(dest="command", required=True)

    connect = subparsers.add_parser("connect", help="connect stdio to a shared worktree service")
    connect.add_argument("--backend", choices=("JetBrains", "LSP"), required=True)
    connect.add_argument("--context", required=True)
    connect.add_argument("--project")
    connect.add_argument("--add-mode", action="append", default=[])
    connect.set_defaults(handler=_connect)

    cleanup = subparsers.add_parser("cleanup", help="stop broker-owned idle services")
    cleanup.add_argument("--idle-seconds", type=int, default=DEFAULT_IDLE_SECONDS)
    cleanup.set_defaults(handler=_cleanup)

    status = subparsers.add_parser("status", help="show broker-owned services")
    status.add_argument("--json", action="store_true")
    status.set_defaults(handler=_status)

    repair = subparsers.add_parser(
        "repair-root", help="repair stale broker-owned state for one exact root"
    )
    repair.add_argument("root")
    repair.add_argument("--json", action="store_true")
    repair.set_defaults(handler=_repair_root)

    leases = subparsers.add_parser("leases", help="show pruned broker lease snapshot")
    leases.add_argument("--json", action="store_true", required=True)
    leases.set_defaults(handler=_leases)

    owner = subparsers.add_parser("owner", help="show resolved logical task owner")
    owner.add_argument("--json", action="store_true")
    owner.set_defaults(handler=_owner)
    return parser


def main(argv: Sequence[str] | None = None) -> int:
    args = _parser().parse_args(argv)
    try:
        return int(args.handler(args))
    except (OSError, RuntimeError, subprocess.SubprocessError) as error:
        print(f"serena-worktree-broker: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
